                "一次移动3步：移动时{3}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-ontargeted",
              "category": "trigger",
              "section": "触发时机",
              "zh": "选作目标时",
              "code": "OnTargeted",
              "description": "场上的该卡牌被选作效果目标时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "来源及其各种属性",
              "examples": [
                "OnTargeted{enemy Spell}",
                "OnTargeted{己方随从}"
              ],
              "status": "可实装"
            },
