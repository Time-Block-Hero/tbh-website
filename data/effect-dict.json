    {
      "id": "scope",
      "zh": "目标范围",
      "en": "Scope & Selector",
      "summary": "定义效果能看见哪些目标，以及如何从候选目标中全选、随机选、玩家选或排序选。",
      "sections": [
        {
          "title": "PreScope 预选范围",
          "entries": [
            {
              "id": "scope-global",
              "category": "scope",
              "section": "PreScope 预选范围",
              "zh": "全场目标",
              "code": "Global",
              "description": "全battlefield符合要求的目标",
              "target": "",
              "input": "",
              "output": "[CardID] | [GridID]",
              "params": "PlayerID，filter，选择策略",
              "examples": [
                "狭义全场：Global{PlayerID:0,1,2} (0代表中立)",
                "己方所有海盗：Global{PlayerID:1, Species: Pirate}"
              ],
              "status": "可实装"
            },
            {
              "id": "scope-rectangular",
              "category": "scope",
              "section": "PreScope 预选范围",
              "zh": "矩形内目标",
              "code": "Rectangular",
              "description": "某个矩形范围内所有符合要求的目标",
              "target": "",
              "input": "",
              "output": "[CardID] | [GridID]",
              "params": "On top of ALL: range bounding box (absolute or rel)",
              "examples": [
                "该单位3x3范围内：Rectangular{relative, centre:self, h:3, w:3}",
                "己方全境：Rectangular{absolute, x_min: 1, x_max:7, y_min:1, y_max:7}"
              ],
              "status": "可实装"
            },
            {
              "id": "scope-distance",
              "category": "scope",
              "section": "PreScope 预选范围",
              "zh": "圆形内目标",
              "code": "Distance",
              "description": "与某个各自距离小于x以内的所有目标 (Manhattan Distance)",
              "target": "",
              "input": "",
              "output": "[CardID] | [GridID]",
              "params": "On top of ALL: centre, radius",
              "examples": [
                "该单位距离2以内的目标：Distance{self, 2}"
              ],
              "status": "可实装"
            },
            {
              "id": "scope-inline",
              "category": "scope",
              "section": "PreScope 预选范围",
              "zh": "线列内目标",
              "code": "InLine",
              "description": "同一个行列内所有符合要求的目标",
              "target": "",
              "input": "",
              "output": "[CardID] | [GridID]",
              "params": "On top of ALL: row/col/both, distance",
              "examples": [
                "狭义同行列：InLine{both, distance:-1}",
                "前方单位：InLine{Col, distance:1}"
              ],
              "status": "可实装"
            },
            {
              "id": "scope-player",
              "category": "scope",
              "section": "PreScope 预选范围",
              "zh": "玩家",
              "code": "Player",
              "description": "对玩家释放的效果，比如提供星能",
              "target": "",
