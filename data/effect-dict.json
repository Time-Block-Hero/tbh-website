  "categories": [
    {
      "id": "trigger",
      "zh": "触发时机",
      "en": "Trigger",
      "summary": "定义效果什么时候进入结算队列，例如入场、发动、回合开始或监听其他卡牌行为。",
      "sections": [
        {
          "title": "触发时机",
          "entries": [
            {
              "id": "trigger-onplace",
              "category": "trigger",
              "section": "触发时机",
              "zh": "入场",
              "code": "OnPlace",
              "description": "当该卡牌被放置于场上时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "来源",
              "examples": [
                "复活：OnPlace{discard_deck}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-oncast",
              "category": "trigger",
              "section": "触发时机",
              "zh": "发动",
              "code": "OnCast",
              "description": "时动阶段，玩家点击卡牌的效果按钮时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "发动次数",
              "examples": [
                "一回合一次：发动{1}",
                "一回合N次：发动{N}",
                "不限次数：发动{-1}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-ondeplace",
              "category": "trigger",
              "section": "触发时机",
              "zh": "离场",
              "code": "OnDePlace",
              "description": "当该卡牌离开场上，且不是被移除时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "去向",
              "examples": [
                "亡语：离场{弃牌堆}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-onattack",
              "category": "trigger",
              "section": "触发时机",
              "zh": "攻击时",
              "code": "OnAttack",
              "description": "随从特供-当场上的该随从发动攻击时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "目标的各种属性（种族、PlayerID、状态、稀有度、etc）",
              "examples": [
                "攻击时{机械种族}",
                "攻击时{中立生物}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-onattacked",
              "category": "trigger",
              "section": "触发时机",
              "zh": "受到攻击时",
              "code": "OnAttacked",
              "description": "随从特供-当场上的该随从受到攻击时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "攻击者各种属性（种族、PlayerID、状态、稀有度、etc）",
              "examples": [
                "受到攻击{机械种族}",
                "受到攻击{敌方生物}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-ondamage",
              "category": "trigger",
              "section": "触发时机",
              "zh": "造成伤害时",
              "code": "OnDamage",
              "description": "当场上的该牌通过效果或攻击对其他随从造成伤害时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "造成伤害的类型（攻击、效果）",
              "examples": [
                "攻击伤害：造成伤害{攻击}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-ondamaged",
              "category": "trigger",
              "section": "触发时机",
              "zh": "受伤时🤕",
              "code": "OnDamaged",
              "description": "随从特供-当场上的该随从受到伤害时。",
              "target": "",
              "input": "",
              "output": "",
              "params": "来源及其各种属性｜伤害类型",
              "examples": [
                "受伤时{机械随从, 攻击}",
                "受伤时{费用高于5的法术}",
                "受伤时{己方随从, 效果伤害}"
              ],
              "status": "可实装"
            },
            {
              "id": "trigger-onmove",
              "category": "trigger",
              "section": "触发时机",
              "zh": "移动时",
              "code": "OnMove",
